#[derive(Parser, Debug)]
#[command(name = "oracle-score", about = "<PRODUCT> tolerance-aware LLM-ON scorer")]
struct Cli {
    #[arg(long, default_value = "oracle/cases")]
    cases: PathBuf,
    #[arg(long, default_value = "oracle/proposals")]
    proposals: PathBuf,
    #[arg(long, default_value = "oracle/report.json")]
    report: PathBuf,
    #[arg(long, default_value = "claude-opus-4-8")]
    model: String,
    #[arg(long, default_value = "unset")]
    ran_at: String,
    #[arg(long, default_value_t = false)]
    self_check: bool,
    #[arg(long)]
    only: Option<String>,
}

